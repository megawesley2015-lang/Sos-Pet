# ============================================================
# VARIÁVEIS DE AMBIENTE — SOS PET
# ============================================================
#
# WORKFLOW:
# 1. Copie este arquivo para .env.local
# 2. Preencha os valores reais (nunca commitar .env.local)
# 3. Em produção (Vercel), configure via Settings → Environment Variables
#
# REGRA: .env.local NUNCA é commitado (proteção via .gitignore)
# ============================================================

# ============================================================
# SUPABASE (Obrigatório — Banco + Auth + Storage)
# ============================================================
# Pegue em: https://supabase.com/dashboard → Project Settings → API

# URL do projeto
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave anon — pública, vai pro browser, respeita RLS
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role — SECRETA, só servidor, bypassa RLS para ops administrativas
# ⚠️ Em Vercel: marque "Secret" e NÃO marque "Available in browser"
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# APP CONFIGURATION (Recomendado em produção)
# ============================================================
# URL canônica — usada em:
#   - emailRedirectTo (confirmar email)
#   - metadata (OpenGraph)
#   - sitemap.xml, robots.txt
# Em dev local pode deixar localhost:3000

NEXT_PUBLIC_SITE_URL=https://sospet.app
NEXT_PUBLIC_APP_URL=https://sospet.app
NEXT_PUBLIC_BASE_URL=https://sospet.app

# ============================================================
# RESEND (Email Transacional)
# ============================================================
# Setup: https://resend.com (freemium)
#
# Passos:
#   1. Crie conta gratuita
#   2. Em "API Keys" → "Create API Key"
#   3. (Opcional) Em "Domains" → adicione e verifique seu domínio
#   4. Em Vercel: Settings → Environment Variables → adicione abaixo
#
# Nota: Enquanto não tiver domínio verificado, use "onboarding@resend.dev"

RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=SOS Pet <onboarding@resend.dev>

# ============================================================
# GOOGLE ANALYTICS (Opcional mas recomendado em produção)
# ============================================================
# Setup: https://analytics.google.com
#
# Pegue o Measurement ID em:
#   Admin → Data Streams → seu stream → "Measurement ID"
# Formato: G-XXXXXXXXXX
#
# Se não definido, o app roda sem tracking (sem overhead)

NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ============================================================
# MERCADO PAGO (Checkout — Plaquinhas & Clube SOS)
# ============================================================
# Setup: https://mercadopago.com.br/developers
#
# Em: "Suas integrações" → "Credenciais" (produção/teste)

# Access Token — SECRETO, só servidor
# ⚠️ Em Vercel: marque "Secret"
MP_ACCESS_TOKEN=APP_USR-xxxx

# Chave pública — público, pode ir pro browser (futura integração SDK)
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxx

# Segredo para validar webhooks de notificações de pagamento
# Configure em: "Suas integrações" → "Webhooks" → "Chave secreta"
# ⚠️ Em Vercel: marque "Secret"
MP_WEBHOOK_SECRET=xxxx

# Link de pagamento do Clube SOS (Checkout Pro)
# Crie em: mercadopago.com.br → "Cobranças" → "Link de pagamento"
# Título: "Clube SOS Premium — R$ 29,90/mês"
NEXT_PUBLIC_CLUBE_SOS_MP_LINK=https://mpago.la/SEU_LINK_AQUI

# ============================================================
# TAGS / PLAQUINHAS (Configuração de Preços)
# ============================================================
# Preço unitário em reais (ex: 39.90)

TAG_PRICE_BRL=39.90
NEXT_PUBLIC_TAG_PRICE_BRL=39.90

# Email & nome do fornecedor que receberá os pedidos automaticamente
SUPPLIER_EMAIL=fornecedor@email.com
SUPPLIER_NAME=Pet Print

# ============================================================
# PRINTFUL (Dropshipping — Sincronização de Catálogo & Pedidos)
# ============================================================
# Setup: https://www.printful.com/developers

# API Key do Printful — SECRETO
# Pegue em: https://www.printful.com/user/account/api → "API key"
# Formato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ⚠️ Em Vercel: marque "Secret"
PRINTFUL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook Secret — usado para validar eventos de entrega
# Configure em: https://www.printful.com/user/account/integrations → "Webhooks"
# ⚠️ Em Vercel: marque "Secret"
PRINTFUL_WEBHOOK_SECRET=xxxx

# Token secreto para chamadas de sync (agendadas ou manuais)
# Uso: curl -X POST https://seusite.com/api/sync/printful \
#      -H "Authorization: Bearer SEU_TOKEN"
# ⚠️ Em Vercel: marque "Secret"
SYNC_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ============================================================
# CLOUDFLARE TURNSTILE (Captcha Anti-Spam)
# ============================================================
# Proteção contra bots no cadastro anônimo de pets
# Setup: https://dash.cloudflare.com/
#
# Em: "Turnstile" → "Crie um site" → copie as chaves

# Site Key — PÚBLICO, vai pro browser, usado no cliente
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Secret Key — SECRETO, só servidor, usado para validação
# ⚠️ Em Vercel: marque "Secret" e NÃO marque "Available in browser"
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000000000000

# ============================================================
# SENTRY (Error Tracking & Performance Monitoring — Opcional)
# ============================================================
# ℹ️  Off-by-default: sem DSN configurado, o app roda SEM Sentry (sem overhead)
#
# Para ativar: ver docs/sentry-setup.md
#   1. Instale pacote adicional
#   2. Renomeie *.example.ts → *.ts
#   3. Configure as variáveis abaixo em Vercel
#
# Setup: https://sentry.io/signup/ → selecione "Next.js"

# DSN do projeto Sentry — deixe vazio para desativar
# Formato: https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=

# Token usado APENAS no build para fazer upload de source maps
# Pegue em: Sentry → Settings → "Account" → "Auth Tokens"
# ⚠️ Em Vercel: marque "Secret"
SENTRY_AUTH_TOKEN=

# Organização no Sentry
SENTRY_ORG=seu-org

# Nome do projeto no Sentry
SENTRY_PROJECT=sos-pet

# Debug mode: captura erros locais em dev (default: skip dev)
# Use: SENTRY_DEBUG=1 (apenas para troubleshooting)
SENTRY_DEBUG=
