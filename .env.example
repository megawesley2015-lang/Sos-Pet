# ============================================================
# Variáveis de ambiente — copie para .env.local e preencha
# ============================================================
# .env.local NUNCA é commitado (proteção via .gitignore).
# Em produção (Vercel), configure tudo isto em
#   Settings → Environment Variables.
# ============================================================

# --- Supabase (obrigatórios) ---
# Pegue em: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co

# Chave anon (pública — vai pro browser, respeita RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Chave service_role (SECRETA — só servidor, bypassa RLS)
# Em Vercel: marque "Secret" e NÃO marque "Available in browser"
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- App (recomendado em produção) ---
# URL canônica do site. Usado em emailRedirectTo, metadata,
# sitemap.xml, robots.txt. Em dev pode deixar default.
NEXT_PUBLIC_SITE_URL=https://sospet.app

# Mesma URL — usado pelo Next em metadataBase
NEXT_PUBLIC_APP_URL=https://sospet.app

# --- Resend (email transacional) ---
# Crie sua conta em resend.com, gere uma API key e verifique um domínio.
# Enquanto não tiver domínio próprio verificado, use o domínio de teste
# do Resend: "onboarding@resend.dev" como remetente.
#
# Passos:
#   1. Acesse https://resend.com e crie uma conta gratuita
#   2. Em API Keys, clique em "Create API Key"
#   3. (Opcional) Em Domains, adicione e verifique seu domínio
#   4. Em Vercel: Settings → Environment Variables, adicione as vars abaixo
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Remetente — use "onboarding@resend.dev" até ter domínio verificado
RESEND_FROM=SOS Pet <onboarding@resend.dev>

# URL base do site (usada nos links dos emails)
NEXT_PUBLIC_BASE_URL=https://project-uobep.vercel.app

# --- Google Analytics (opcional mas recomendado em produção) ---
# Crie uma propriedade GA4 em analytics.google.com
# Pegue o Measurement ID em: Admin → Data Streams → seu stream → Measurement ID
# Formato: G-XXXXXXXXXX
# Se não definido, o componente GoogleAnalytics simplesmente não renderiza.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# --- Mercado Pago (módulo de plaquinhas) ---
# Crie sua conta em mercadopago.com.br/developers
# Em: Suas integrações → Credenciais de produção/teste

# Access Token (SECRETO — só servidor)
MP_ACCESS_TOKEN=APP_USR-xxxx

# Chave pública (usada futuramente no SDK client-side)
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxxx

# Segredo para validar assinatura dos webhooks
# Configure em: Suas integrações → Webhooks → Chave secreta
MP_WEBHOOK_SECRET=xxxx

# Link de Pagamento do Clube SOS (Checkout Pro)
# Crie em: mercadopago.com.br → Cobranças → Link de pagamento
# Título: "Clube SOS Premium — R$ 29,90/mês"
NEXT_PUBLIC_CLUBE_SOS_MP_LINK=https://mpago.la/SEU_LINK_AQUI

# --- Plaquinha ---
# Preço da plaquinha em reais (ex: 39.90)
TAG_PRICE_BRL=39.90
NEXT_PUBLIC_TAG_PRICE_BRL=39.90

# Email do fornecedor que receberá os pedidos automaticamente
SUPPLIER_EMAIL=fornecedor@email.com
SUPPLIER_NAME=Pet Print

# --- Printful (dropshipping de produtos) ---
# API Key do Printful para sincronizar catálogo e criar pedidos
# Pegue em: https://www.printful.com/user/account/api → API key
# Formato: xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PRINTFUL_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Webhook Secret do Printful (para validar eventos de entrega)
# Configure em: https://www.printful.com/user/account/integrations → Webhooks
PRINTFUL_WEBHOOK_SECRET=xxxx

# Token secreto para permitir chamadas de sync agendadas e manuais
# Exemplo: curl -X POST https://seusite.com/api/sync/printful -H "Authorization: Bearer SEU_TOKEN"
SYNC_TOKEN=xxxxxxxxxxxxxxxxxxxx

# --- Cloudflare Turnstile (Captcha anti-spam) ---
# Proteção contra bots no cadastro anônimo de pets.
# Crie uma conta em: https://dash.cloudflare.com/
# Vá para: Turnstile → Crie um site
# Pegue:
#   - Site Key (público — pode ir pro browser)
#   - Secret Key (SECRETO — só servidor)
#
# Site Key: usada no cliente (obrigatória)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Secret Key: usada no servidor para validar (obrigatória)
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000000000000

# --- Sentry (observabilidade — opcional) ---
# Off-by-default: sem DSN, o app roda sem Sentry e sem overhead.
# Ativação: ver docs/sentry-setup.md (instala pacote, renomeia *.example.ts).
# Crie projeto em: https://sentry.io/signup/  →  Next.js
NEXT_PUBLIC_SENTRY_DSN=

# Token usado APENAS no build pra subir source maps (recomendado em prod)
# Pegue em: Sentry → Settings → Account → Auth Tokens
SENTRY_AUTH_TOKEN=
SENTRY_ORG=seu-org
SENTRY_PROJECT=sos-pet

# Se setar SENTRY_DEBUG=1 em dev, captura erros locais também (default: skip dev)
SENTRY_DEBUG=
